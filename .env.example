# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI Providers (최소 하나 필수)
GMS_KEY=                    # SSAFY GMS 프록시 키 (4/3 만료)
GEMINI_API_KEY=             # Google AI Studio — GMS 만료 후 사용
# ANTHROPIC_API_KEY=        # Claude (선택)
# OPENAI_API_KEY=           # OpenAI (선택, 임베딩에 사용)

# 임베딩 (GMS_KEY로 OpenAI 임베딩 프록시 사용 중)
# 별도 OpenAI 키가 있으면 embeddings.ts 수정 필요

# BYOK 암호화 키 (32바이트 hex)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# 외부 API
KCI_API_KEY=                # 공공데이터포털 KCI 논문정보 API
